<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.mybatis_test.mapper.StudentMapper">

    <select id="findAll" resultType="StudentDto">
        SELECT
            student_id,
            student_no,
            name,
            department,
            grade
        FROM student
        ORDER BY student_id
    </select>

    <select id="findById" parameterType="long" resultType="StudentDto">
        SELECT
            student_id,
            student_no,
            name,
            department,
            grade
        FROM student
        WHERE student_id = #{studentId}
    </select>

</mapper>
